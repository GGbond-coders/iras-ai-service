<?xml version="1.0" encoding="UTF-8" ?>
<!--
  ==============================================================================
  IRAS 智能简历诊断系统 - JobMapper MyBatis XML 映射文件
  ==============================================================================
  此文件定义了 JobMapper 接口中复杂 SQL 的映射规则。
  包含两个动态 SQL 查询：
  1. searchJobs - 多字段模糊搜索 + 分页（支持职位名称、城市、薪资范围）
  2. countSearchJobs - 与 searchJobs 相同条件的记录总数统计

  动态 SQL 特性：
  - 使用 <where> 标签自动处理 AND 前缀
  - 使用 <if> 标签实现条件判断，仅在参数非空时拼接 SQL
  - 薪资字段需要去除 'k'/'K' 后缀后转换为数字进行比较
  ==============================================================================
-->
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.iras.mapper.JobMapper">

    <!--
      多字段模糊搜索职位（支持分页）
      参数：
        - jobName: 职位名称（模糊匹配，可选）
        - city: 城市（模糊匹配，可选）
        - salaryMin: 最低薪资（可选）
        - salaryMax: 最高薪资（可选）
        - offset: 分页偏移量
        - size: 每页记录数
      返回：符合条件的职位列表
    -->
    <select id="searchJobs" resultType="com.iras.entity.JobInfo">
        SELECT * FROM job_info
        <where>
            <!-- 职位名称模糊匹配 -->
            <if test="jobName != null and jobName != ''">
                AND job_name LIKE CONCAT('%', #{jobName}, '%')
            </if>
            <!-- 城市模糊匹配 -->
            <if test="city != null and city != ''">
                AND city LIKE CONCAT('%', #{city}, '%')
            </if>
            <!-- 最低薪资筛选（去除 k/K 后缀后转换为数字比较） -->
            <if test="salaryMin != null and salaryMin != ''">
                AND CAST(REPLACE(REPLACE(salary, 'k', ''), 'K', '') AS UNSIGNED) &gt;= #{salaryMin}
            </if>
            <!-- 最高薪资筛选（去除 k/K 后缀后转换为数字比较） -->
            <if test="salaryMax != null and salaryMax != ''">
                AND CAST(REPLACE(REPLACE(salary, 'k', ''), 'K', '') AS UNSIGNED) &lt;= #{salaryMax}
            </if>
        </where>
        ORDER BY id DESC          <!-- 按 ID 降序排列（最新数据在前） -->
        LIMIT #{offset}, #{size}  <!-- 分页：从 offset 开始取 size 条 -->
    </select>

    <!--
      统计搜索结果总数（与 searchJobs 使用相同的搜索条件）
      用于计算分页信息中的总记录数和总页数
    -->
    <select id="countSearchJobs" resultType="long">
        SELECT COUNT(*) FROM job_info
        <where>
            <!-- 职位名称模糊匹配 -->
            <if test="jobName != null and jobName != ''">
                AND job_name LIKE CONCAT('%', #{jobName}, '%')
            </if>
            <!-- 城市模糊匹配 -->
            <if test="city != null and city != ''">
                AND city LIKE CONCAT('%', #{city}, '%')
            </if>
            <!-- 最低薪资筛选 -->
            <if test="salaryMin != null and salaryMin != ''">
                AND CAST(REPLACE(REPLACE(salary, 'k', ''), 'K', '') AS UNSIGNED) &gt;= #{salaryMin}
            </if>
            <!-- 最高薪资筛选 -->
            <if test="salaryMax != null and salaryMax != ''">
                AND CAST(REPLACE(REPLACE(salary, 'k', ''), 'K', '') AS UNSIGNED) &lt;= #{salaryMax}
            </if>
        </where>
    </select>

</mapper>
